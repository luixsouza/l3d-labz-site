# Copie para .env e ajuste. Em dev, pode deixar tudo no padrão (SQLite + LocMem).

SECRET_KEY=dev-insecure-change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banco ---
# Padrão: SQLite. Para usar Postgres, descomente abaixo (ou defina DATABASE_ENGINE=postgres):
# DATABASE_ENGINE=postgres
# POSTGRES_DB=nexora
# POSTGRES_USER=nexora
# POSTGRES_PASSWORD=nexora
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# --- Cache ---
# Padrão: LocMemCache. Para Redis real:
# REDIS_URL=redis://127.0.0.1:6379/1
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

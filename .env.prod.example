# L3D Labz — variáveis de PRODUÇÃO (server caseiro + Cloudflare Tunnel).
# Copie para `.env.prod` no server e preencha. NUNCA comite o .env.prod real.
#   cp .env.prod.example .env.prod && nano .env.prod

# --- Django ---
DEBUG=False
# Gere uma chave forte:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=TROQUE-POR-UMA-CHAVE-FORTE-E-UNICA

# Domínio + hosts. Inclui localhost p/ os healthchecks/testes locais no server.
DOMAIN=l3dlabz.com.br
ALLOWED_HOSTS=l3dlabz.com.br,www.l3dlabz.com.br,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://l3dlabz.com.br,https://www.l3dlabz.com.br

# Cloudflare faz o HTTPS na borda; deixe o redirect com ela ("Always Use HTTPS").
SECURE_SSL_REDIRECT=False

# --- Postgres ---
DATABASE_ENGINE=postgres
POSTGRES_DB=l3dlabz
POSTGRES_USER=l3dlabz
POSTGRES_PASSWORD=TROQUE-POR-UMA-SENHA-FORTE
POSTGRES_PORT=5432
# POSTGRES_HOST é "db" (definido pelo compose).

# --- Redis ---
# REDIS_URL é redis://redis:6379/0 (definido pelo compose).

# --- Cloudflare Tunnel ---
# Crie o tunnel no painel Zero Trust da Cloudflare e cole o token aqui.
# Depois suba o conector:  docker compose --env-file .env.prod --profile tunnel up -d cloudflared
CLOUDFLARE_TUNNEL_TOKEN=
